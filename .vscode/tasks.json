{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe сборка активного файла",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                // "-DNDEBUG",
                "-g",
                "-std=c++17",
                "-I${workspaceFolder}/src",
                "-I${workspaceFolder}/include",
                "-IC:/msys64/ucrt64/include/luajit-2.1",
                "-L${workspaceFolder}/lib",
                "@${workspaceFolder}/.vscode/sources.txt",
                "-lglfw3dll", 
                "-lopengl32",
                "-lglew32",
                "-lluajit-5.1",
                "-lopenal",
                "-lvorbis",
                "-lvorbisfile",
                "-lvorbisenc",
                "-lz",
                "-lfmt",
                "-lspdlog",
                "-o",
                "${workspaceFolder}/build/ChromaForge.exe",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Сборка исполняемого файла ChromaForge"
        }
    ],
    "version": "2.0.0"
}
