{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Отладка ChromaForge",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/ChromaForge.exe",
            "cwd": "${workspaceFolder}/build",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
